# ----------------------------------------------------------------------------
# RoleCall environment variables
#
# Local dev:  copy this file to `.env.local` and fill in real values.
# Vercel:     add each of these in Project Settings → Environment Variables.
# ----------------------------------------------------------------------------

# --- Clerk authentication (required) ---------------------------------------
# Create a project at https://clerk.com and copy the API keys.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY="your-clerk-publishable-key"
CLERK_SECRET_KEY="your-clerk-secret-key"

# --- Vercel Postgres (required) --------------------------------------------
# Add a Postgres database to your Vercel project; Vercel injects POSTGRES_URL
# automatically in production. For local dev, run `vercel env pull .env.local`
# or paste the connection string here.
POSTGRES_URL="your-postgres-connection-string"

# --- Resend email invites (optional) ---------------------------------------
# Get an API key at https://resend.com. Invites are skipped if this is unset.
RESEND_API_KEY="your-resend-api-key"
# Domain used in the invite "from" address (defaults to rolecall.app).
RESEND_FROM_DOMAIN="rolecall.app"

# --- Script file uploads via Vercel Blob (optional) ------------------------
# Add Vercel Blob storage (Storage → Create → Blob, free tier) to enable
# uploading script files. Vercel injects this automatically once connected.
# Without it, the script text editor still works — only file upload is disabled.
BLOB_READ_WRITE_TOKEN="your-vercel-blob-token"

# --- App URL (optional) ----------------------------------------------------
# Used to build absolute invite links. Set to your local URL in development.
# On Vercel the app falls back to VERCEL_PROJECT_PRODUCTION_URL / VERCEL_URL.
NEXT_PUBLIC_APP_URL="http://localhost:3000"
